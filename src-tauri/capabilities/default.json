{
  "identifier": "default",
  "description": "Default capability set for Claude Swarm",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "bun-broker",
          "cmd": "bun",
          "args": true,
          "sidecar": false
        },
        {
          "name": "claude-agent",
          "cmd": "claude",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bun-broker",
          "cmd": "bun",
          "args": true,
          "sidecar": false
        },
        {
          "name": "claude-agent",
          "cmd": "claude",
          "args": true,
          "sidecar": false
        }
      ]
    },
    "shell:allow-open",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "dialog:allow-open"
  ]
}
